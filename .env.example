# ─── Supabase ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
#
# Email magic link: no extra env vars — redirect URLs are configured in the
# Supabase Dashboard (Authentication → URL configuration). Allow e.g.
# http://localhost:5173/** and https://your-domain/** so /login can recover the session.

# Used by Python backend scripts (service role bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Push Notifications (optional – Firebase Cloud Messaging) ────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development

# Public URL of the deployed wedding app (invite links in SMS/WhatsApp & sync_guests.py)
VITE_APP_URL=https://your-site.vercel.app
# Same URL for Python scripts if you prefer a single name:
APP_PUBLIC_URL=https://your-site.vercel.app

# ─── Google Sheet sync (backend/sync_guests.py) ─────────────────────────────
# GOOGLE_SHEET_ID=from_docs_google_com_spreadsheets_d___HERE___
# GOOGLE_SHEET_NAME=Guests
# INVITE_COUPLE_LABEL=Nav & Sanju
